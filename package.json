{
  "private": true,
  "name": "valcordia-space",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run type-check && npm run lint && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "ship": "node -e \"const f='version.json';const j=JSON.parse(require('fs').readFileSync(f));const p=j.version.split('.');p[2]=+p[2]+1;j.version=p.join('.');require('fs').writeFileSync(f,JSON.stringify(j,null,2)+'\\n');console.log('v'+j.version);require('fs').writeFileSync('.ship-version',j.version)\" && npx devvit upload --version $(cat .ship-version) && npx devvit install valcordia_space_dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.4",
    "@devvit/web": "0.13.4",
    "@hono/node-server": "2.0.3",
    "devvit": "0.13.4",
    "hono": "4.12.21",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "3.9.6",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vitest": "^4.1.10"
  }
}
